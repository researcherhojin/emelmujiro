# ============================================
# Emelmujiro Backend — Environment Variables
# ============================================
# Copy to .env and fill in real values.

# ---- Required ----
SECRET_KEY=your-secret-key-here-minimum-50-characters
ALLOWED_HOSTS=emelmujiro.com,api.emelmujiro.com,localhost,127.0.0.1

# ---- Database ----
# Leave DATABASE_URL empty to use SQLite (default, recommended for Mac Mini)
# Set to PostgreSQL URL to use PostgreSQL: docker compose --profile postgres up
DATABASE_URL=
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---- Core ----
DEBUG=False
CORS_ALLOWED_ORIGINS=https://emelmujiro.com
CSRF_TRUSTED_ORIGINS=https://emelmujiro.com,https://api.emelmujiro.com

# ---- Email (optional — contact form uses Google Form iframe for now) ----
# EMAIL_HOST is hardcoded to smtp.gmail.com in settings.py (not configurable via env)
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ---- Security (production) ----
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_SSL_REDIRECT=True

# ---- reCAPTCHA (optional) ----
# RECAPTCHA_PUBLIC_KEY=
# RECAPTCHA_PRIVATE_KEY=

# ---- Monitoring (optional) ----
ADMIN_EMAIL=admin@emelmujiro.com
