# ============================================
# Emelmujiro Backend — Environment Variables
# ============================================
# Copy to .env and fill in real values.

# ---- Required ----
SECRET_KEY=your-secret-key-here-minimum-50-characters
ALLOWED_HOSTS=api.emelmujiro.com,localhost,127.0.0.1

# ---- Database ----
# Leave DATABASE_URL empty to use SQLite (default, recommended for Mac Mini)
# Set to PostgreSQL URL to use PostgreSQL: docker compose --profile postgres up
DATABASE_URL=
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---- Core ----
DEBUG=False
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://researcherhojin.github.io
CSRF_TRUSTED_ORIGINS=https://researcherhojin.github.io,https://api.emelmujiro.com

# ---- Email (나중에 설정 — Contact은 DB 저장만 먼저) ----
# EMAIL_HOST=smtp.gmail.com
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ---- Security (프로덕션) ----
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
SECURE_SSL_REDIRECT=True

# ---- Chat / Redis (1.0에서 제외 — 나중에 활성화) ----
# REDIS_URL=redis://localhost:6379/0

# ---- reCAPTCHA (선택) ----
# RECAPTCHA_PUBLIC_KEY=
# RECAPTCHA_PRIVATE_KEY=

# ---- Monitoring (선택) ----
# SENTRY_DSN=
ADMIN_EMAIL=admin@emelmujiro.com
