FROM python:3.12-slim

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# Set environment variables.
# UV_LINK_MODE=copy is required for bind-mounted source on macOS — without it
# uv tries to hardlink across the bind boundary and fails. Matches prod
# Dockerfile. UV_COMPILE_BYTECODE is intentionally NOT set in dev because
# auto-reload regenerates .pyc files anyway and the precompile step adds
# ~5s to dev container start with no benefit.
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_LINK_MODE=copy

# Set work directory
WORKDIR /app

# Install system dependencies (--no-install-recommends keeps the image lean)
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    gettext \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies (cached layer)
COPY pyproject.toml uv.lock ./
RUN uv sync --frozen

# Copy project
COPY . .

# Create non-root user
RUN adduser --disabled-password --gecos '' appuser && \
    chown -R appuser:appuser /app

# Switch to non-root user
USER appuser

# Expose port
EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD uv run python manage.py check || exit 1

# Run development server with auto-reload
CMD ["uv", "run", "python", "manage.py", "runserver", "0.0.0.0:8000"]
