# Vite Environment Variables
# Copy this file to .env and update the values

# API Configuration
VITE_API_URL=http://localhost:8000/api

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# External Services (optional)
VITE_GA_TRACKING_ID=
VITE_SENTRY_DSN=

# App Configuration
VITE_APP_NAME=에멜무지로
VITE_VERSION=1.0.0
VITE_PUBLIC_URL=
