{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://emelmujiro.com",
  "dependencies": {
    "@sentry/react": "^10.65.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tiptap/core": "^3.27.1",
    "form-data": "^4.0.6",
    "@tiptap/extension-code-block-lowlight": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-task-item": "^3.27.1",
    "@tiptap/extension-task-list": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "axios": "^1.18.1",
    "dompurify": "^3.4.12",
    "i18next": "^26.3.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.24.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "remark-gfm": "^4.0.1",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.5.4",
    "eslint": "^10.6.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.18",
    "prettier": "^3.9.4",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "npx concurrently -n sitemap,tsc \"npm run generate:sitemap\" \"tsc -p tsconfig.build.json\" && vite build && node scripts/prerender.js && cp build/index.html build/404.html",
    "build:no-prerender": "npx concurrently -n sitemap,tsc \"npm run generate:sitemap\" \"tsc -p tsconfig.build.json\" && vite build && cp build/index.html build/404.html",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run --bail=1 --no-coverage",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "analyze:bundle": "source-map-explorer 'build/assets/*.js'",
    "check:css": "node scripts/check-css.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,md}",
    "format:check": "prettier --check src/**/*.{js,jsx,ts,tsx,css,md}",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "clean": "rm -rf build node_modules/.cache",
    "clean:all": "rm -rf build node_modules coverage playwright-report test-results",
    "validate": "npm run lint && npm run type-check && npm run test:coverage"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "@tiptap/core": "^3.27.1",
    "form-data": "^4.0.6"
  }
}
