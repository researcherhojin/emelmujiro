{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "homepage": "https://emelmujiro.com",
  "dependencies": {
    "@sentry/react": "^10.11.0",
    "@tiptap/extension-code-block-lowlight": "^3.20.4",
    "@tiptap/extension-dropcursor": "^3.20.4",
    "@tiptap/extension-image": "^3.20.4",
    "@tiptap/extension-link": "^3.20.4",
    "@tiptap/extension-placeholder": "^3.20.4",
    "@tiptap/extension-task-item": "^3.20.4",
    "@tiptap/extension-task-list": "^3.20.4",
    "@tiptap/extension-typography": "^3.20.4",
    "@tiptap/extension-underline": "^3.20.4",
    "@tiptap/pm": "^3.20.4",
    "@tiptap/react": "^3.20.4",
    "@tiptap/starter-kit": "^3.20.4",
    "@vitejs/plugin-legacy": "^8.0.0",
    "axios": "^1.11.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.37.0",
    "i18next": "^25.5.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.577.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.6.2",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.8.2",
    "remark-gfm": "^4.0.1",
    "web-vitals": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.55.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.3.3",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-testing-library": "^7.16.0",
    "globals": "^17.3.0",
    "jsdom": "^29.0.0",
    "msw": "^2.11.2",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "sitemap": "^9.0.1",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.19",
    "terser": "^5.46.0",
    "typescript": "^5.9.2",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "npm run generate:sitemap && tsc -p tsconfig.build.json && vite build && node scripts/prerender.js && cp build/index.html build/404.html",
    "build:no-prerender": "npm run generate:sitemap && tsc -p tsconfig.build.json && vite build && cp build/index.html build/404.html",
    "preview": "vite preview",
    "test": "vitest",
    "test:ci": "vitest run --bail=1 --no-coverage",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "generate:sitemap": "node scripts/generate-sitemap.js",
    "analyze:bundle": "source-map-explorer 'build/assets/*.js'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/**/*.{js,jsx,ts,tsx,css,md}",
    "format:check": "prettier --check src/**/*.{js,jsx,ts,tsx,css,md}",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "clean": "rm -rf build node_modules/.cache",
    "clean:all": "rm -rf build node_modules coverage playwright-report test-results",
    "validate": "npm run lint && npm run type-check && npm run test:coverage"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "minimatch": ">=10.2.1"
  }
}
