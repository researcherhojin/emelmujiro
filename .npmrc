# React 19.2 peers resolve cleanly, but a FRESH `npm install` still needs
# --legacy-peer-deps: eslint-plugin-jsx-a11y@6.10.2 peer-caps eslint at ^9
# while we run ^10 (ERESOLVE otherwise). Kept disabled here on purpose —
# `npm ci` rebuilds the existing lockfile without it; pass the flag manually
# only when regenerating the lockfile. See CLAUDE.md Gotcha #13.
# legacy-peer-deps=true
loglevel=warn
