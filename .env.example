# Environment Configuration Template
# Copy this file to .env and update with your values

# ===========================================
# General Settings
# ===========================================
DEBUG=True
TAG=latest

# ===========================================
# Database Configuration
# ===========================================
# SQLite is the default (no DATABASE_URL needed).
# Set DATABASE_URL only when using PostgreSQL (docker compose --profile postgres).
# DB_NAME=emelmujiro
# DB_USER=postgres
# DB_PASSWORD=changeme
# DB_HOST=db
# DB_PORT=5432
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===========================================
# Django Settings
# ===========================================
SECRET_KEY=your-secret-key-here-generate-a-secure-one
ALLOWED_HOSTS=emelmujiro.com,api.emelmujiro.com,localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

# ===========================================
# Frontend Configuration
# ===========================================
VITE_API_URL=http://localhost:8000/api
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
VITE_GA_TRACKING_ID=
VITE_SENTRY_DSN=
VITE_APP_NAME=에멜무지로
VITE_SITE_URL=https://emelmujiro.com
VITE_CONTACT_EMAIL=contact@emelmujiro.com

# ===========================================
# Port Configuration
# ===========================================
BACKEND_PORT=8000
FRONTEND_PORT=8080

# ===========================================
# Email Configuration
# ===========================================
# EMAIL_BACKEND, EMAIL_HOST, EMAIL_PORT, EMAIL_USE_TLS are hardcoded in settings.py.
# Only these are read from environment:
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
ADMIN_EMAIL=

# ===========================================
# reCAPTCHA (required in production)
# ===========================================
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# ===========================================
# Monitoring & Analytics
# ===========================================
SENTRY_DSN=

# ===========================================
# Docker Build Arguments
# ===========================================
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
BUILDKIT_PROGRESS=plain
