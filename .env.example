# Docker Compose orchestration — NO app secrets here.
# Backend config: backend/.env (local dev) or backend/.env.production (Docker prod)
# Frontend config: frontend/.env.example → frontend/.env

# Ports
TAG=latest
BACKEND_PORT=8000
FRONTEND_PORT=8080

# PostgreSQL (only with: docker compose --profile postgres up)
DB_NAME=emelmujiro
DB_USER=postgres
DB_PASSWORD=changeme
DB_PORT=5432

# Umami analytics
UMAMI_PORT=3001
UMAMI_APP_SECRET=replace-with-secrets-token-urlsafe-32
UMAMI_DB_PASSWORD=replace-with-secrets-token-urlsafe-16

# Docker build
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
BUILDKIT_PROGRESS=plain
