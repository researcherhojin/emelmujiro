# Environment Configuration Template
# Copy this file to .env and update with your values

# ===========================================
# General Settings
# ===========================================
ENVIRONMENT=development
DEBUG=True
TAG=latest

# ===========================================
# Database Configuration
# ===========================================
# SQLite is the default (no DATABASE_URL needed).
# Set DATABASE_URL only when using PostgreSQL (docker compose --profile postgres).
# DB_NAME=emelmujiro
# DB_USER=postgres
# DB_PASSWORD=changeme
# DB_HOST=db
# DB_PORT=5432
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ===========================================
# Redis Configuration
# ===========================================
# Only needed when using Redis (docker compose --profile redis).
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ===========================================
# Django Settings
# ===========================================
SECRET_KEY=your-secret-key-here-generate-a-secure-one
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===========================================
# Frontend Configuration
# ===========================================
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false
VITE_GA_TRACKING_ID=
VITE_SENTRY_DSN=

# ===========================================
# Port Configuration
# ===========================================
BACKEND_PORT=8000
FRONTEND_PORT=80
FRONTEND_SSL_PORT=443

# ===========================================
# Email Configuration
# ===========================================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@emelmujiro.com

# ===========================================
# Monitoring & Analytics
# ===========================================
SENTRY_DSN=
GA_TRACKING_ID=

# ===========================================
# Security
# ===========================================
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0
CSRF_TRUSTED_ORIGINS=http://localhost:5173
CORS_ALLOW_CREDENTIALS=True

# ===========================================
# Docker Build Arguments
# ===========================================
DOCKER_BUILDKIT=1
COMPOSE_DOCKER_CLI_BUILD=1
BUILDKIT_PROGRESS=plain
